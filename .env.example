# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketplace?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (RS256 Keys - generate with: openssl genrsa -out jwt-private.key 2048 && openssl rsa -in jwt-private.key -pubout -out jwt-public.key)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# AWS S3
AWS_S3_BUCKET="marketplace-products"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# Cloudinary
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Email (SendGrid)
SENDGRID_API_KEY="SG...."
EMAIL_FROM="noreply@marketplace.com"

# OAuth
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# App
NODE_ENV="development"
PORT=3000
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# MFA
MFA_APP_NAME="Marketplace"

# Logging
LOG_LEVEL="info"
