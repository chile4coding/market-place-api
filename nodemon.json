{
  "watch": ["src"],
  "ext": "ts,js,json",
  "ignore": ["src/**/*.spec.ts", "src/**/*.test.ts", "node_modules", "dist", "*.d.ts"],
  "exec": "npx ts-node -r tsconfig-paths/register src/server.ts",
  "env": {
    "NODE_ENV": "development"
  },
  "verbose": true,
  "delay": 1000,
  "restartable": "rs",
  "colours": true,
  "events": {
    "restart": "echo 'Server restarted'",
    "crash": "echo 'Server crashed'",
    "exit": "echo 'Server exited'"
  }
}
